<!--
  Adaptive-icon override for the .debug.pulse variant.

  Lives under app/src/debug/res/ so it shadows the main src set's
  ic_launcher.xml only during debug builds — release retains the stock
  amberagent icon. Each layer points at the pulse_launcher_* vector
  drawables in the same source set:

    background  → solid chartreuse fill
    foreground  → ink ECG trace + sport-orange focal dot
    monochrome  → silhouette for Android 13+ themed icons

  No XML attributes other than the three layer references; the OS
  applies the user's launcher mask (squircle / circle / square) on top.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/pulse_launcher_background" />
    <foreground android:drawable="@drawable/pulse_launcher_foreground" />
    <monochrome android:drawable="@drawable/pulse_launcher_monochrome" />
</adaptive-icon>
