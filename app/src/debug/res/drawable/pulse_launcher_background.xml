<!--
  Pulse adaptive-icon background: solid chartreuse fill.

  The 108x108 viewport matches the Android adaptive-icon spec; the OS
  launcher applies its own mask (squircle / circle / square) on top, so
  the chartreuse fills whatever mask shape the user's launcher uses. No
  internal shape is drawn here — the foreground's ECG mark provides all
  the visual hierarchy, and the background is purely the brand color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#FFD6FF3F" />
</vector>
