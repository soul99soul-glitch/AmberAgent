    },
    "rate_limit": {
      "http_status": 403,
      "map_to": "DEGRADED"
    }
  },
  "permissions": [
    "read_cookie:remember_user_token",
    "detect_login",
    "detect_rate_limit"
  ],
  "notes": "Pure profile — no native adapter."
}
