{
  "id": "stackoverflow",
  "name": "Stack Overflow",
  "version": 1,
  "origins": [
    "https://stackoverflow.com",
    "https://stackexchange.com",
    "https://serverfault.com",
    "https://superuser.com"
  ],
  "capabilities": ["read"],
  "hints": {
    "interactive_selectors": {
      "question_title": "h1[itemprop=name], h1.question-hyperlink",
      "answer": "div.answer",
      "answer_body": "div.answer .s-prose, div.answer .post-text",
      "vote_count": ".js-vote-count"
    }
  },
  "notes": "Public — no auth needed for read. The profile points wm_extract at the question/answer DOM."
}
